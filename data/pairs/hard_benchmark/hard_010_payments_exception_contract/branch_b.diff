+++ b/payments_handler.py
@@ -0,0 +1,7 @@
+from payments_guard import ensure_payments_positive, PaymentsError
+
+def safe_payments(value):
+    try:
+        return ensure_payments_positive(value)
+    except PaymentsError:
+        return 0
--- a/test_payments_handler.py
