+def test_toolcalls_validate_input_with_string():
+    """Test that ToolCalls.validate_input can handle string input."""
+    input_str = 'search(query="hello world")'
+ 
+    result = ToolCalls.model_validate(input_str)
+    assert isinstance(result, ToolCalls)
+    assert len(result.tool_calls) == 1
+    assert result.tool_calls[0].name == "search"
+    assert result.tool_calls[0].args == {"query": "hello world"}
+
+
+def test_toolcalls_validate_input_with_multiple_calls():
+    """Test that ToolCalls.validate_input can handle multiple calls in string."""
+    input_str = '''search(query="nlp")
+translate(text="world", lang="fr")'''
+ 
+    result = ToolCalls.model_validate(input_str)
+    assert isinstance(result, ToolCalls)
+    assert len(result.tool_calls) == 2
+    assert result.tool_calls[0].name == "search"
+    assert result.tool_calls[1].name == "translate"
+
+
+def test_parse_python_calls_basic():
+    """Test basic Python call parsing."""
+    from dspy.adapters.types.tool import parse_python_calls
+ 
+    input_str = 'search(query="hello")'
+    result = parse_python_calls(input_str)
+ 
+    expected = {
+        "tool_calls": [
+            {"name": "search", "args": {"query": "hello"}}
+        ]
+    }
+    assert result == expected
+
+
+def test_parse_python_calls_multiple():
+    """Test parsing multiple Python calls."""
+    from dspy.adapters.types.tool import parse_python_calls
+ 
+    input_str = 'search(query="nlp"); translate(text="world", lang="fr")'
+    result = parse_python_calls(input_str)
+ 
+    expected = {
+        "tool_calls": [
+            {"name": "search", "args": {"query": "nlp"}},
+            {"name": "translate", "args": {"text": "world", "lang": "fr"}}
+        ]
+    }
+    assert result == expected
+
+
+def test_parse_python_calls_positional_error():
+    """Test that positional arguments raise a clear error."""
+    from dspy.adapters.types.tool import parse_python_calls
+ 
+    input_str = 'search("hello world")'
+ 
+    with pytest.raises(ValueError, match="Only keyword arguments supported"):
+        parse_python_calls(input_str)
+
+
