 func methodNotAllowedHandler(w http.ResponseWriter, r *http.Request) {
 	w.WriteHeader(405)
-	w.Write(nil)
-}
+	w.Write([]byte("Method not allowed"))
+}
+
+// SetMethodNotAllowedResponseWithAllow is a helper function for middleware
+// to set the proper Method Not Allowed response with the Allow header.
+// The methods parameter is a list of allowed HTTP methods for the route.
+func SetMethodNotAllowedResponseWithAllow(w http.ResponseWriter, methods []string) {
+	if len(methods) > 0 {
+		w.Header().Set("Allow", strings.Join(methods, ", "))
+	}
+
+	// Set status code
+	w.WriteHeader(http.StatusMethodNotAllowed)
+
+	// Don't write body (follows HTTP standard that body is optional)
+}

