+def test_image_block_resolve_image_with_size(png_1px: bytes):
+    b = ImageBlock(image=png_1px)
+    buf, size = b.resolve_image_with_size()
+    assert isinstance(buf, BytesIO)
+    assert size == len(png_1px)
+    assert buf.read() == png_1px
+
+    buf, size = b.resolve_image_with_size(as_base64=True)
+    decoded = base64.b64decode(b.image)
+    assert isinstance(buf, BytesIO)
+    assert size == len(base64.b64encode(decoded))
