@@ -161,6 +161,21 @@
         b.resolve_image()
 
 
+def test_image_block_force_mimetype(png_1px):
+    block = ImageBlock(image=png_1px)
+    block.image_to_base64()
+    result = block.resolve_image(as_base64=True, force_mimetype="image/png")
+    result_bytes = result.getvalue()
+    assert result_bytes.startswith(b"data:image/png;base64,")
+    # ensure the base64 content is still present after prefix
+    # strip 'data:image/png;base64,' and compare base64 content directly
+    prefix = b"data:image/png;base64,"
+    assert result_bytes.startswith(prefix)
+    b64_content = result_bytes[len(prefix):]
+    # The block.image is already base64-encoded bytes, so compare as-is
+    assert b64_content == block.image
+
