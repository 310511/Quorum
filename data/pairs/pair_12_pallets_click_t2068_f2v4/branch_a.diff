 def test_fast_edit(runner):
     result = click.edit("a\nb", editor="sed -i~ 's/$/Test/'")
     assert result == "aTest\nbTest\n"
+
+def test_edit_timeout_parameter_validation():
+    """Test timeout parameter validation in edit function."""
+    with pytest.raises(ValueError):
+        click.edit("test", timeout=0)
+
+    with pytest.raises(ValueError):
+        click.edit("test", timeout=-5)
+
+def test_edit_timeout_expired():
+    """Test that edit function times out properly."""
+    # Use a command that ignores arguments and sleeps
+    with pytest.raises(click.ClickException, match="Editing timed out after 1 seconds"):
+        click.edit("test", editor="sh -c 'sleep 2'", timeout=1)
+
+def test_edit_timeout_not_exceeded():
+    """Test that edit function works normally when timeout is not exceeded."""
+    # Use fast sed command with reasonable timeout that modifies the file in-place
+    result = click.edit("test\n", editor="sed -i~ 's/test/success/'", timeout=10)
+    assert result == "success\n"
+
+def test_edit_file_timeout():
+    """Test timeout functionality when editing files."""
+    import os
+    import tempfile
+
+    # Create a temporary file
+    with tempfile.NamedTemporaryFile(mode="w", delete=False) as f:
+        f.write("test content\n")
+        temp_file = f.name
+
+    try:
+        # Test timeout with file editing
+        with pytest.raises(
+            click.ClickException, match="Editing timed out after 1 seconds"
+        ):
+            click.edit(filename=temp_file, editor="sh -c 'sleep 2'", timeout=1)
+    finally:
+        # Clean up
+        os.unlink(temp_file)
 
 
