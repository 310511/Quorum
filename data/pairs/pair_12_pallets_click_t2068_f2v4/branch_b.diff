+def test_edit_command_construction():
+    """Test that editor commands are properly constructed with arguments."""
+    import shlex
+
+    from click._termui_impl import Editor
+
+    editor = Editor(editor="vim", editor_args=["-n", "+10", "-c", "set number"])
+
+    # Simulate the command construction logic
+    cmd_parts = ["vim"]
+    cmd_parts.extend(editor.editor_args)
+    cmd_parts.append("test.txt")
+
+    cmd = " ".join(shlex.quote(part) for part in cmd_parts)
+
+    expected_cmd = shlex.join(["vim", "-n", "+10", "-c", "set number", "test.txt"])
+
+    assert cmd == expected_cmd
