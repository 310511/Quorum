+@pytest.mark.skipif(platform.system() == "Windows", reason="No echo on Windows.")
+def test_edit_file_with_editor_args(runner, tmp_path):
+    """Test editor_args with file editing."""
+    test_file = tmp_path / "test.txt"
+    test_file.write_text("original content")
+
+    # Use echo to append text to the file (simulating editor behavior)
+    click.edit(
+        filename=str(test_file),
+        editor="sh",
+        editor_args=["-c", f"echo 'new line' >> {test_file}"],
+    )
+
+    # Check that the file was modified
+    content = test_file.read_text()
+    assert "original content" in content
+    assert "new line" in content
