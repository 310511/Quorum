+def test_sed_with_editor_args(runner):
+    """Test editor_args parameter with sed command."""
+    result = click.edit(
+        "hello\nworld",
+        editor="sed",
+        editor_args=["-i", "-e", "s/hello/hi/", "-e", "s/world/universe/"],
+    )
+    assert result == "hi\nuniverse\n"
+
+
+def test_edit_with_no_editor_args(runner):
+    """Test that empty editor_args list works correctly."""
+    # This should behave the same as not providing editor_args
+    result = click.edit(
+        "test content", editor="cat", editor_args=[], require_save=False
+    )
+    result_2 = click.edit(
+        "test content", editor="cat", editor_args=None, require_save=False
+    )
+    assert result == "test content\n"
+    assert result_2 == "test content\n"
