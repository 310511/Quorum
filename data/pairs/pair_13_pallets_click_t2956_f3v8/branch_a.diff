+def test_batch_size_basic(runner):
+    """Test basic batch_size functionality."""
+
+    @click.command()
+    @click.option("--item", multiple=True, batch_size=2)
+    def cli(item):
+        results = []
+        for batch in item:
+            results.append(list(batch))
+        click.echo(str(results))
+
+    result = runner.invoke(
+        cli, ["--item", "a", "--item", "b", "--item", "c", "--item", "d"]
+    )
+    assert not result.exception
+    assert result.output == "[['a', 'b'], ['c', 'd']]\n"
+
+
+def test_batch_size_unfull_batch(runner):
+    """Test batch_size with partial last batch."""
+
+    @click.command()
+    @click.option("--item", multiple=True, batch_size=2)
+    def cli(item):
+        results = []
+        for batch in item:
+            results.append(list(batch))
+        click.echo(str(results))
+
+    # Test with no items
+    result = runner.invoke(cli, [])
+    assert not result.exception
+    assert result.output == "[]\n"
+
+    # Test with one item
+    result = runner.invoke(cli, ["--item", "a"])
+    assert not result.exception
+    assert result.output == "[['a']]\n"
+
+    result = runner.invoke(
+        cli, ["--item", "a", "--item", "b", "--item", "c"]
+    )
+    assert not result.exception
+    assert result.output == "[['a', 'b'], ['c']]\n"
+
+
+def test_batch_size_validation_errors():
+    """Test batch_size validation errors."""
+    # batch_size without multiple should raise TypeError
+    with pytest.raises(
