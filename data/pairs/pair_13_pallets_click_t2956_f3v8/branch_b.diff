+    def _track_option_change(
+        self, name: str, value: t.Any, source: ParameterSource
+    ) -> None:
+        """Track an option value change for history tracking.
+
+        :param name: The name of the parameter.
+        :param value: The new value.
+        :param source: The source of the value.
+        """
+        if not self._track_changes:
+            return
+
+        import time
+
+        if name not in self._option_history:
+            self._option_history[name] = []
+
+        self._option_history[name].append(
+            {"value": value, "source": source, "timestamp": time.time()}
+        )
+
+    def get_option_history(self, name: str) -> list[dict[str, t.Any]] | None:
+        """Get the history of value changes for an option.
+
+        Returns a list of dictionaries containing the history of value changes
+        for the specified option. Each dictionary contains:
+        - 'value': The value that was set
+        - 'source': The ParameterSource indicating where the value came from
+        - 'timestamp': Unix timestamp when the value was set
+
+        :param name: The name of the option to get history for.
+        :return: List of change history or None if no history is tracked.
+
+        .. versionadded:: 8.3
+        """
+        if not self._track_changes:
+            return None
+        return self._option_history.get(name, [])
 
 
