+    def test_filesystem_loader_fallback_basic(self, tmp_path):
+        """Test basic fallback functionality."""
+        primary_dir = tmp_path / "primary"
+        fallback_dir = tmp_path / "fallback"
+        primary_dir.mkdir()
+        fallback_dir.mkdir()
+ 
+        # Create template only in fallback
+        (fallback_dir / "fallback.html").write_text("FALLBACK")
+ 
+        loader = loaders.FileSystemLoader(str(primary_dir), fallback_searchpath=str(fallback_dir))
+        env = Environment(loader=loader)
+ 
+        tmpl = env.get_template("fallback.html")
+        assert tmpl.render().strip() == "FALLBACK"
+
+    def test_filesystem_loader_fallback_priority(self, tmp_path):
+        """Test that primary paths take priority over fallback paths."""
+        primary_dir = tmp_path / "primary"
+        fallback_dir = tmp_path / "fallback"
+        primary_dir.mkdir()
+        fallback_dir.mkdir()
+ 
+        # Create same template in both directories
+        (primary_dir / "template.html").write_text("PRIMARY")
+        (fallback_dir / "template.html").write_text("FALLBACK")
+ 
+        loader = loaders.FileSystemLoader(str(primary_dir), fallback_searchpath=str(fallback_dir))
+        env = Environment(loader=loader)
+ 
+        tmpl = env.get_template("template.html")
+        assert tmpl.render().strip() == "PRIMARY"
+
+    def test_filesystem_loader_fallback_multiple_paths(self, tmp_path):
+        """Test fallback with multiple fallback paths."""
+        primary_dir = tmp_path / "primary"
+        fallback1_dir = tmp_path / "fallback1"
+        fallback2_dir = tmp_path / "fallback2"
+        primary_dir.mkdir()
+        fallback1_dir.mkdir()
+        fallback2_dir.mkdir()
+ 
+        # Create templates in different fallback directories
+        (fallback1_dir / "template1.html").write_text("FALLBACK1")
+        (fallback2_dir / "template2.html").write_text("FALLBACK2")
+ 
+        loader = loaders.FileSystemLoader(
+            str(primary_dir), 
+            fallback_searchpath=[str(fallback1_dir), str(fallback2_dir)]
+        )
+        env = Environment(loader=loader)
+ 
+        tmpl1 = env.get_template("template1.html")
+        assert tmpl1.render().strip() == "FALLBACK1"
+ 
+        tmpl2 = env.get_template("template2.html")
+        assert tmpl2.render().strip() == "FALLBACK2"
+
