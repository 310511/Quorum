+    def test_mark_corners(self, tmp_path: Path) -> None:
+        # Create a test image
+        test_image = Image.new("RGB", (100, 80), color=(50, 100, 150))
+        output_file = tmp_path / "marked_corners.png"
+
+        # Save with corner marking
+        test_image.save(output_file, mark_corners=True)
+
+        # Verify file was created successfully
+        assert output_file.exists()
+
+        # Load saved image and check corner pixels
+        with Image.open(output_file) as marked_img:
+            # Top-left pixel should be red
+            assert marked_img.getpixel((0, 0)) == (255, 0, 0)
+
+            # Bottom-right pixel should be red
+            assert marked_img.getpixel((marked_img.width - 1, marked_img.height - 1)) == (255, 0, 0)
+
+            # Center pixel should still be the original color
+            center_x, center_y = marked_img.width // 2, marked_img.height // 2
+            assert marked_img.getpixel((center_x, center_y)) == (50, 100, 150)
+
+    def test_no_corner_marking(self, tmp_path: Path) -> None:
+        # Create a test image
+        test_image = Image.new("RGB", (50, 40), color=(200, 200, 200))
+
+        # Create two versions - one with marking, one without
+        with_marking = tmp_path / "with_marking.png"
+        without_marking = tmp_path / "without_marking.png"
+
+        test_image.save(with_marking, mark_corners=True)
+        test_image.save(without_marking)  # Default is no marking
+
+        # Both files should exist
+        assert with_marking.exists()
+        assert without_marking.exists()
+
+        # Check pixels in unmarked image
+        with Image.open(without_marking) as result:
+            assert result.getpixel((0, 0)) == (200, 200, 200)
+            assert result.getpixel((result.width - 1, result.height - 1)) == (200, 200, 200)
+
+        # Check pixels in marked image
+        with Image.open(with_marking) as result:
+            assert result.getpixel((0, 0)) == (255, 0, 0)
+            assert result.getpixel((result.width - 1, result.height - 1)) == (255, 0, 0)
 
